          "reviewBody": "Ótimo serviço e atendimento excelente. A clínica é super limpa e muito bem localizada."
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Deise Elen Simões" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "Ótimo lugar, realmente superou as expectativas. Podem ir sem medo."
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Rhayssa Macedo" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "Clínica excelente, com ótimos profissionais!"
        }
