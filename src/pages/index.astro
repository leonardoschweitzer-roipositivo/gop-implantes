  "@graph": [
    {
      "@type": "Dentist",
      "@id": "https://gopimplantes.br/#clinica",
      "name": "GOP Implantes",
      "description": "Clínica odontológica em São Bernardo do Campo (SP), com mais de 35 anos de experiência: implantes dentários, prótese, ortodontia, endodontia, periodontia, alinhadores invisíveis, harmonização facial, facetas e lentes, odontologia digital e dentística restauradora.",
