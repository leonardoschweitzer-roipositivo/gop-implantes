---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="GOP Implantes — Implantes dentários e odontologia completa em SBC"
  description="Clínica odontológica em São Bernardo do Campo (SP). Implantes, prótese, ortodontia, endodontia, alinhadores invisíveis, harmonização facial e mais — há mais de 35 anos. Agende sua consulta."
  canonical="https://gopimplantes.br/"
  ogDescription="Sorria com confiança. Implantes dentários e odontologia completa em São Bernardo do Campo, com mais de 35 anos de experiência."
  twDescription="Implantes dentários e odontologia completa em São Bernardo do Campo, há mais de 35 anos. Agende sua consulta na GOP Implantes."
  geo={true}
  heroDark={true}
>
  <Fragment slot="head">
<script type="application/ld+json">
{
