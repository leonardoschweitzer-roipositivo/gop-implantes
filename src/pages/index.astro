        "addressRegion": "SP",
        "addressCountry": "BR"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": -23.6939, "longitude": -46.5650 },
      "hasMap": "https://www.google.com/maps/search/?api=1&query=GOP+Implantes+S%C3%A3o+Bernardo+do+Campo",
      "sameAs": ["https://www.instagram.com/gopimplantes/"],
