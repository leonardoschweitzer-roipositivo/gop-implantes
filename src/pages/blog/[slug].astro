---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const data = post.data;

const base = "https://gopimplantes.br";
const url = `${base}/blog/${post.id}.html`;
const img = data.image ? `${base}${data.image}` : `${base}/images/blog/${post.id}.jpg`;

const jsonld = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Início", item: `${base}/` },
        { "@type": "ListItem", position: 2, name: "Conteúdos", item: `${base}/#conteudos` },
        { "@type": "ListItem", position: 3, name: data.title, item: url },
      ],
    },
    {
      "@type": "BlogPosting",
      headline: data.title,
      description: data.description,
      url,
      mainEntityOfPage: url,
      image: img,
      articleSection: data.category,
      inLanguage: "pt-BR",
      datePublished: data.date,
      dateModified: "2026-06-22",
      author: { "@type": "Organization", name: "GOP Implantes", url: `${base}/` },
      publisher: {
        "@type": "Organization",
        name: "GOP Implantes",
        logo: { "@type": "ImageObject", url: `${base}/favicon.svg` },
      },
    },
  ],
};
---
<BaseLayout
  title={`${data.title} — GOP Implantes`}
  description={data.description}
  canonical={url}
  ogType="article"
  ogTitle={data.title}
  ogDescription={data.description}
  twDescription={data.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  </Fragment>

  <article class="article">
    <div class="wrap">
      <a href="/#conteudos" class="art-back">← Voltar para Conteúdos</a>
      <span class="art-cat">{data.category}</span>
      <h1 class="art-title">{data.title}</h1>
      <div class="art-meta">
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>{data.readTime}</span>
        <span>Por GOP Implantes</span>
      </div>
      <div class="art-cover"><img src={data.image ?? `/images/blog/${post.id}.jpg`} alt={data.title} loading="lazy" onerror="this.remove()" /></div>
      <div class="prose">
        <Content />
        <div class="art-cta">
          <h3>{data.ctaTitle ?? "Pronto para cuidar do seu sorriso?"}</h3>
          <p>{data.ctaText ?? "Agende uma consulta na GOP Implantes."}</p>
          <a href="https://wa.me/5511985140604" class="btn btn-white" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.6-.1-.4-.1-.9-.3-1.5-.6-2.7-1.2-4.5-3.9-4.6-4.1-.1-.2-1.1-1.4-1.1-2.7 0-1.3.7-1.9 .9-2.2.2-.2.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.4.6c-.1.2-.3.3-.1.6.2.3.8 1.3 1.7 2 .8.5 1.1.6 1.4.5.2-.1.4-.4.6-.7.2-.3.4-.2.6-.2l1.7.8c.2.1.4.2.4.4.1.2.1.9-.1 1.5Z"/></svg>
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
